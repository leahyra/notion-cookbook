# Copy to `.env` for local testing. Never commit real credentials.

# One repository per Worker deployment. Pair the familiar owner/name with
# GitHub's immutable numeric repository ID.
GITHUB_REPOSITORY=example-org/example-repo
GITHUB_REPOSITORY_ID=123456789

# Recommended: a GitHub App installation limited to this repository.
# Repository permissions: Contents read/write and Metadata read.
GITHUB_AUTH_MODE=installation
GITHUB_APP_CLIENT_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=

# Alternative: a fine-grained PAT limited to the same repository and
# Contents read/write. Set GITHUB_AUTH_MODE=pat before using it.
GITHUB_TOKEN=
