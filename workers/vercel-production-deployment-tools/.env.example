# Team-scoped token from a principal with project access and Full Production
# Deployment permission.
VERCEL_ACCESS_TOKEN=replace-with-a-dedicated-automation-token
# Find these in Vercel Project Settings or `.vercel/project.json` after linking.
VERCEL_TEAM_ID=team_example
VERCEL_PROJECT_ID=prj_example

# Optional: up to three application endpoints that return a direct 2xx response.
VERCEL_HEALTH_PATHS_JSON=[]
# Optional: sent only to the generated deployment hostname.
VERCEL_PROTECTION_BYPASS_SECRET=
