# Copy this file to `.env` and fill in only the values for the selected mode.
# Never commit `.env` or real credentials. For a deployed Worker, configure
# these values with `ntn workers env set KEY=value`.

# Choose `pat` for the shortest setup or `user` for GitHub App user OAuth.
GITHUB_AUTH_MODE=pat

# Required in every mode: immutable numeric ID of the one GitHub user whose
# stars this deployment owns. The Worker verifies it against GET /user before
# every stars page so a rotated or reauthorized credential cannot change scope.
GITHUB_USER_ID=

# Fine-grained PAT mode. Grant only read-only Starring account permission.
GITHUB_TOKEN=

# GitHub App user OAuth mode. Grant Starring read access, install the app on
# every relevant account, include expected private repos, then authorize.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
