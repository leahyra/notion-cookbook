# Copy this file to `.env` and fill in your own values for local testing.
# `.env` is gitignored. Never commit real credentials.
# For a deployed Worker, set these with `ntn workers env set KEY=value`.

# Required: immutable ID returned as `id` by Todoist's GET /api/v1/user.
# Every capability checks this value before reading tasks, projects, or recent
# completions.
TODOIST_USER_ID=

# Required: personal API token from Todoist Settings > Integrations > Developer.
TODOIST_API_TOKEN=
