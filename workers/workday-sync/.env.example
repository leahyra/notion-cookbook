# Copy this file to `.env` for local testing. `.env` is gitignored.
# For a deployed worker, set these with `ntn workers env set KEY=value`.

# Exact HTTPS Human Resources WWS endpoint copied from your Workday tenant.
# Keep the version in this URL aligned with WORKDAY_API_VERSION.
WORKDAY_API_URL=https://tenant1.myworkday.com/ccx/service/example_tenant/Human_Resources/v46.1

# WWS version tested by this recipe. Upgrade only after reviewing that version's
# Get_Workers schema and validating both sync previews in a non-production tenant.
WORKDAY_API_VERSION=v46.1

# Exact HTTPS OAuth token endpoint copied from Workday's View API Clients report.
WORKDAY_TOKEN_URL=https://tenant1.myworkday.com/ccx/oauth2/example_tenant/token

# Dedicated API Client for Integrations values. Never commit real secrets.
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=
WORKDAY_REFRESH_TOKEN=

# IANA time zone approved by the Workday owner for effective-dated records.
# Example: America/New_York. Do not leave this unset or choose by assumption.
WORKDAY_EFFECTIVE_TIME_ZONE=

# Optional non-secret label (50 characters maximum) for Workday server-log
# correlation. SOAP calls include it as wd-external-application-id and add a
# fresh wd-external-request-id. Do not put employee data or credentials here.
# WORKDAY_EXTERNAL_APPLICATION_ID=notion-workday-sync
